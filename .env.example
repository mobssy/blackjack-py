# JackPy - 환경변수 설정 예시
# 실제 사용 시 .env 파일로 복사하여 값을 입력하세요
# cp .env.example .env

# ━━━━━━━━━━━━━━━━━━━━━━━━━━
# Telegram Bot Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━
# BotFather에서 발급받은 텔레그램 봇 토큰
TELEGRAM_TOKEN=your_telegram_bot_token_here

# 관리자 텔레그램 ID (쉼표로 구분, 공백 없이)
# 예: ADMIN_IDS=123456789,987654321
ADMIN_IDS=your_admin_telegram_id

# ━━━━━━━━━━━━━━━━━━━━━━━━━━
# Database Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━
# PostgreSQL 데이터베이스 URL
# 형식: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jackpy

# SQL 쿼리 로깅 (개발용, 프로덕션에서는 false)
SQL_ECHO=false

# ━━━━━━━━━━━━━━━━━━━━━━━━━━
# Payment Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━
# 입금 계좌 정보 (멀티라인 지원)
BANK_ACCOUNT_INFO="국민은행 123-456-789012\n예금주: JackPy"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━
# Application Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━
# 환경 (development/production)
ENVIRONMENT=development

# 로그 레벨 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# ━━━━━━━━━━━━━━━━━━━━━━━━━━
# Optional: External Services
# ━━━━━━━━━━━━━━━━━━━━━━━━━━
# Redis URL (게임 세션 저장용, 선택사항)
# REDIS_URL=redis://localhost:6379/0

# Sentry DSN (에러 추적용, 선택사항)
# SENTRY_DSN=your_sentry_dsn_here

# ━━━━━━━━━━━━━━━━━━━━━━━━━━
# Game Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━
# 초기 지급 금액
INITIAL_WALLET=1000

# 일일 보상 금액 (무료/VIP)
DAILY_REWARD_FREE=200
DAILY_REWARD_VIP=500

# 광고 표시 확률 (0.0 ~ 1.0)
AD_PROBABILITY=0.15
